{
  "manifest_version": 3,
  "name": "OPL Assistant",
  "version": "1.0.0",
  "description": "Personalized powerlifting context on openpowerlifting.org — percentiles, qualifying totals, comparisons.",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://www.openpowerlifting.org/*", "*://openpowerlifting.org/*"],
      "js": ["src/content/drawer.tsx"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.openpowerlifting.org/u/*", "*://openpowerlifting.org/u/*"],
      "js": ["src/content/lifter-inject.tsx"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://opl-coach-proxy.ewl172003.workers.dev/*",
    "https://www.openpowerlifting.org/*",
    "https://openpowerlifting.org/*"
  ],
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "commands": {
    "toggle-drawer": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Toggle OPL Assistant drawer"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://opl-coach-proxy.ewl172003.workers.dev;"
  }
}
