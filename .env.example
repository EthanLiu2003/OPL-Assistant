# Rename to .env and fill in any keys your solution needs.
# We have accounts with these providers and will supply real keys when reviewing.

# LLM proxy (Cloudflare Worker secret — deployed via wrangler, not shipped to extension)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Supabase (extension-bundled; anon key is public by design, protected by RLS)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=xxxxx

# LLM proxy URL (extension-bundled; points at the deployed Worker)
VITE_PROXY_URL=https://opl-coach-proxy.<your-subdomain>.workers.dev

# Unused by this project, kept for Luma reviewers:
OPENAI_API_KEY=sk-xxxxx
ELEVEN_LABS_API_KEY=xxxxx
GOOGLE_CLOUD_API_KEY=xxxxx
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_REGION=us-west-2
